FROM mcr.microsoft.com/playwright/python:v1.42.0-jammy

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --no-cache-dir -e ".[dev,playwright]" \
    && playwright install chromium

ENV PYTHONUNBUFFERED=1
ENV EG_ENV=dev

EXPOSE 8080

CMD ["python", "-m", "ingestion.main", "run", "--group", "playwright_360"]
