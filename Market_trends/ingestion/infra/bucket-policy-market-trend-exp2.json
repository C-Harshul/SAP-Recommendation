{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowIngestionUser",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::318651457457:user/market-trend-exp-bronze-writer"
      },
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::market-trend-exp2"
    },
    {
      "Sid": "AllowIngestionUserObjects",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::318651457457:user/market-trend-exp-bronze-writer"
      },
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::market-trend-exp2/bronze/*"
    }
  ]
}
