# Production-only configuration
# Copy to recommendation_engine/.env OR use DAPL/.env at repo root (auto-discovered)

EG_LLM_MODE=live
GOOGLE_API_KEY=
# GEMINI_API_KEY=   # alias for GOOGLE_API_KEY
EG_DATA_SOURCE=s3
EG_ALLOW_FIXTURES=0
# LLM-enrich bronze trends when gold/ is empty (0 = skip, avoids extra Gemini calls)
EG_ENRICH_BRONZE_TRENDS=0
EG_TREND_ENRICHMENT_BATCH_SIZE=8
EG_REQUIRE_USER_SIGNALS=0
# Community: s3 | fixtures (mock JSON under src/recommendation_engine/fixtures/)
# Community: fixtures = hardcoded mock_community.json | s3 = real posts on S3
EG_COMMUNITY_SOURCE=fixtures

EG_S3_BUCKET=market-trend-exp2
EG_S3_BRONZE_PREFIX=bronze
EG_S3_GOLD_TREND_PREFIX=gold/trend_signals
AWS_REGION=us-east-1
AWS_PROFILE=market-trend-exp-bronze-writer

EG_LOOKBACK_DAYS=14
EG_MAX_MARKET_RECORDS=80
# Gemini free tier: ~100 embed requests/min — small batches + delay between calls
EG_EMBED_BATCH_SIZE=20
EG_EMBED_DELAY_SECONDS=14

# Gemini Flash (default for all stages)
EG_MODEL_EXTRACT=gemini-2.5-flash
EG_MODEL_SYNTHESIZE=gemini-2.5-flash
EG_MODEL_CLUSTER=gemini-2.5-flash
EG_MODEL_RANK_QUALITATIVE=gemini-2.5-flash
EG_MODEL_WRITEUP=gemini-2.5-flash
EG_MODEL_TREND_ENRICHMENT=gemini-2.5-flash

# Embeddings — Databricks Foundation Model API (same workspace as Market_trends)
# PAT must include scope: model-serving (User Settings → Developer → Access tokens)
DATABRICKS_HOST=https://dbc-de47fb26-18b8.cloud.databricks.com
DATABRICKS_TOKEN=
EG_EMBEDDING_PROVIDER=databricks
EG_DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en
EG_EMBED_BATCH_SIZE=32
EG_EMBED_DELAY_SECONDS=0.5
# Fallback only: EG_EMBEDDING_PROVIDER=gemini + GOOGLE_API_KEY
EG_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EG_EMBEDDING_DIM=1024

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=eg-recommendation-engine

EG_TOP_MISSIONS=10
EG_CLUSTER_COSINE_THRESHOLD=0.85
EG_TREND_RETRIEVAL_K=5
EG_WEIGHTS_VERSION=v1.0
EG_PROMPT_VERSION=v1.0
EG_GIT_SHA=dev

# Persist pipeline results on disk; skip re-run when S3 inputs + config unchanged
EG_PIPELINE_CACHE=1
EG_PIPELINE_FORCE_RERUN=0
# EG_PIPELINE_CACHE_DIR=recommendation_engine/.eg_cache
# Upload full snapshot + dashboard JSON to S3 (same bucket as inputs)
EG_PIPELINE_RESULTS_S3=1
# IAM bronze-writer can only PutObject under bronze/* — do not use bucket-root gold/
EG_S3_PIPELINE_RESULTS_PREFIX=bronze/gold/pipeline_runs

# Gmail API newsletter sender (OAuth client + refresh token from Google Cloud OAuth app)
# OAuth scopes: gmail.send + userinfo.email (add both on GCP OAuth consent screen)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
EG_NEWSLETTER_DEFAULT_TO=harshulc2001@gmail.com
